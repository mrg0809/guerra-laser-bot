# Copia a .env y rellena los valores reales:
#   cp .env.example .env

# --- Google Gemini ---
GOOGLE_API_KEY=tu_api_key_de_google_ai_studio
# Opcional: modelo (por defecto gemini-1.5-flash)
# GEMINI_MODEL=gemini-1.5-flash

# --- Supabase (tabla productos) ---
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=tu_service_role_o_anon_key

PRODUCTOS_TABLE=products
PRODUCT_MEDIA_TABLE=product_media
PRODUCTOS_COL_NOMBRE=name
PRODUCTOS_COL_DESCRIPCION=description
PRODUCTOS_COL_SKU=sku
PRODUCTOS_COL_SLUG=slug
PRODUCTOS_COL_CATEGORY_ID=category_id

CATEGORIES_TABLE=categories
CATEGORIES_COL_NOMBRE=name
CATEGORIES_COL_SLUG=slug

# URLs públicas (slug en products / categories)
PUBLIC_SITE_BASE=https://guerralaser.com
# Ruta con {slug}; ajusta si tu web usa otra estructura (ej. /producto/{slug})
PUBLIC_PRODUCT_PATH_TEMPLATE=/productos/{slug}
PUBLIC_CATEGORY_PATH_TEMPLATE=/categorias/{slug}

# --- Chatwoot (API para enviar respuestas) ---
# URL base sin barra final, ej: https://app.chatwoot.com
CHATWOOT_BASE_URL=https://tu-instancia.chatwoot.com
CHATWOOT_API_TOKEN=tu_token_de_agente_o_bot
# ID numérico de la cuenta (fallback si el webhook no trae account_id)
CHATWOOT_ACCOUNT_ID=2

# --- App ---
# Segundos de espera tras el último mensaje antes de llamar a Gemini (debounce)
DEBOUNCE_SECONDS=8
# Puerto de uvicorn (local: python main.py; en Docker usa GUERRA_LASER_PORT en compose)
PORT=8000

# --- Docker (docker-compose.yml) ---
# Puerto publicado en la máquina host (mapeo host:contenedor)
# GUERRA_LASER_PORT=8000
#
# Chatwoot en otro contenedor: CHATWOOT_BASE_URL = URL interna del API Rails
#   ej. http://rails:3000  (nombre del servicio en el compose de Chatwoot)
# Webhook en Chatwoot hacia este bot: http://guerra-laser-ai:8000/webhook
